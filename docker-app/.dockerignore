# ============================================================================
# .dockerignore - Exclude files from Docker build context
# ============================================================================
# This file tells Docker which files/folders to exclude from the build context
# Excluding unnecessary files makes the build faster and the image smaller
# ============================================================================

# Git files
.git
.gitignore
.gitattributes

# Documentation
README.md
*.md

# Build scripts (not needed in the image)
build-and-push.sh

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS files
Thumbs.db
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
